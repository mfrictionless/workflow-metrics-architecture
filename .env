# Local working-example defaults. Not for production use — adjust any value
# here to fit your environment (e.g. change ODS_POSTGRES_PORT if 5432 is
# already in use on your machine). docker compose loads this file automatically.

ODS_POSTGRES_PORT=5433
ODS_POSTGRES_DB=ods
ODS_POSTGRES_USER=postgres
ODS_POSTGRES_PASSWORD=postgres

# Default number of files `make simulate` creates per invocation.
# Override per-run: make simulate COUNT=1000
SIMULATOR_FILE_COUNT=5
