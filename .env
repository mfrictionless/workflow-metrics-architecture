# Local working-example defaults. Not for production use — adjust any value
# here to fit your environment (e.g. change ODS_POSTGRES_PORT if 5432 is
# already in use on your machine). docker compose loads this file automatically.

ODS_POSTGRES_PORT=5433
ODS_POSTGRES_DB=ods
ODS_POSTGRES_USER=postgres
ODS_POSTGRES_PASSWORD=postgres

# Warehouse Postgres -- a second, separate instance from the ODS above (Raw/
# Silver/Gold/Mart land here starting M2.5). Different default port so both
# can run side by side without a manual edit.
WAREHOUSE_POSTGRES_PORT=5434
WAREHOUSE_POSTGRES_DB=warehouse
WAREHOUSE_POSTGRES_USER=postgres
WAREHOUSE_POSTGRES_PASSWORD=postgres

# Default number of files `make simulate` creates per invocation.
# Override per-run: make simulate COUNT=1000
SIMULATOR_FILE_COUNT=5

# Number of persons/users per pooled role (loan officer, processor, title
# agent, notary, county recorder) the simulator reuses across files. BORROWER
# is never pooled -- each file gets its own (see simulator/simulate.py).
POOL_SIZE_PER_ROLE=3

# Host-facing Kafka broker port (adjust if 9094 is already in use).
KAFKA_BROKER_PORT=9094

# Kafka Connect worker's REST API port (adjust if 8083 is already in use).
CONNECT_REST_PORT=8083
