[sqlfluff]
dialect = postgres
templater = jinja
exclude_patterns = warehouse/dbt/target
max_line_length = 120

# The dbt models use Jinja (source(), a custom dedup_latest macro). The jinja
# templater renders them without the full dbt stack: apply_dbt_builtins stubs
# ref()/source()/config(), and load_macros_from_path loads project macros so
# dedup_latest resolves. Plain Postgres DDL (ods/, warehouse/ddl) has no Jinja,
# so it passes through this templater unchanged.
[sqlfluff:templater:jinja]
apply_dbt_builtins = true
load_macros_from_path = warehouse/dbt/macros
